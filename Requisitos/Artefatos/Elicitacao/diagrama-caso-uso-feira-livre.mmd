%% Diagrama de caso de uso UML para o sistema de gestão das feiras livres

actor SecretariaMunicipal as SM
actor Feirante as F
actor Fiscal as FI

SM -- (Cadastrar Feirante)
SM -- (Atualizar/Remover Feirante)
SM -- (Registrar Feira)
SM -- (Associar Barraca a Feirante)
SM -- (Registrar Pagamento de Taxa)
SM -- (Gerar Relatórios)
SM -- (Emitir Licença)
SM -- (Autenticar Usuário)
SM -- (Consultar Histórico de Alterações)
SM -- (Configurar Feira)

F -- (Pagar Taxa)
F -- (Solicitar Licença)
F -- (Consultar Próxima Feira)

FI -- (Consultar Feirantes Autorizados)
FI -- (Autenticar Usuário)

(Solicitar Licença) ..> (Cadastrar Feirante) : <<include>>
(Registrar Pagamento de Taxa) ..> (Pagar Taxa) : <<include>>

note right of SM
  Secretaria Municipal
  - Gerencia feiras, feirantes, taxas
end
note right of F
  Feirante
  - Participa das feiras
end
note right of FI
  Fiscal
  - Fiscaliza e consulta feirantes
end
